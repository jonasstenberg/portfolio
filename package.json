{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "prettier": "prettier --check --ignore-path=.prettierignore --ignore-unknown src",
    "prettier:fix": "prettier --write --ignore-path=.prettierignore --ignore-unknown src",
    "lint": "pnpm prettier && eslint src",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@svgr/plugin-prettier": "^8.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-svgr": "^4.5.0"
  },
  "packageManager": "pnpm@10.10.0"
}
